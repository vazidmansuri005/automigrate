{
  "name": "automigrate",
  "version": "0.1.0",
  "description": "Universal test migration tool — converts Selenium, Cypress, Puppeteer, Appium, WebdriverIO, and Robot Framework test suites to Playwright",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "automigrate": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:e2e": "vitest --config vitest.e2e.config.ts",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test:run",
    "test:run": "vitest run",
    "cli": "tsx src/cli/index.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "playwright",
    "selenium",
    "cypress",
    "puppeteer",
    "appium",
    "webdriverio",
    "robot-framework",
    "migration",
    "test-automation",
    "codemod",
    "ast",
    "refactoring",
    "testing",
    "e2e"
  ],
  "author": "automigrate contributors",
  "license": "MIT",
  "homepage": "https://github.com/automigrate-tool/automigrate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/automigrate-tool/automigrate.git"
  },
  "bugs": {
    "url": "https://github.com/automigrate-tool/automigrate/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@babel/generator": "^7.24.0",
    "@babel/parser": "^7.24.0",
    "@babel/traverse": "^7.24.0",
    "@babel/types": "^7.24.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "cosmiconfig": "^9.0.0",
    "diff": "^5.2.0",
    "fast-glob": "^3.3.0",
    "glob": "^13.0.6",
    "inquirer": "^9.2.0",
    "listr2": "^8.0.0",
    "ora": "^8.0.0",
    "p-limit": "^5.0.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-c-sharp": "^0.21.0",
    "tree-sitter-java": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "ts-morph": "^22.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "@types/diff": "^5.2.0",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.3.0",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  }
}
